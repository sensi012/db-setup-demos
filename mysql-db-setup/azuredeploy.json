{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "ARM template to deploy an Azure Database for MySQL Flexible Server, a database, and configure firewall rules."
  },
  "parameters": {
    "serverName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 63,
      "metadata": {
        "description": "Name of the Azure Database for MySQL Flexible Server."
      }
    },
    "administratorLogin": {
      "type": "string",
      "defaultValue": "mysqladmin",
      "metadata": {
        "description": "Administrator login name for the MySQL server."
      }
    },
    "administratorLoginPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Administrator password for the MySQL server."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the MySQL server."
      }
    },
    "version": {
      "type": "string",
      "defaultValue": "8.0.21",
      "allowedValues": [
        "5.7",
        "8.0.21"
      ],
      "metadata": {
        "description": "MySQL version."
      }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Standard_B1ms",
      "metadata": {
        "description": "The name of the sku, e.g. Standard_B1ms, Standard_D2ds_v4, Standard_E2ds_v4."
      }
    },
    "skuTier": {
      "type": "string",
      "defaultValue": "Burstable",
      "allowedValues": [
        "Burstable",
        "GeneralPurpose",
        "MemoryOptimized"
      ],
      "metadata": {
        "description": "The tier of the sku."
      }
    },
    "storageSizeGB": {
      "type": "int",
      "defaultValue": 20,
      "minValue": 20,
      "maxValue": 16384,
      "metadata": {
        "description": "Max storage allowed for the server."
      }
    },
    "storageIops": {
      "type": "int",
      "defaultValue": 360,
      "metadata": {
        "description": "Storage IOPS for the server."
      }
    },
    "backupRetentionDays": {
      "type": "int",
      "defaultValue": 7,
      "minValue": 1,
      "maxValue": 35,
      "metadata": {
        "description": "Backup retention days for the server."
      }
    },
    "geoRedundantBackup": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "Enable geo-redundant backup."
      }
    },
    "highAvailabilityMode": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Disabled",
        "ZoneRedundant",
        "SameZone"
      ],
      "metadata": {
        "description": "High availability mode for the server."
      }
    },
    "databaseName": {
      "type": "string",
      "defaultValue": "appdatabase",
      "metadata": {
        "description": "Name of the MySQL database."
      }
    },
    "allowAllIPs": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Allow public access from all IPs (for dev/test)."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "environment": "dev",
        "project": "mysqldb-setup",
        "managedBy": "ARM"
      },
      "metadata": {
        "description": "Resource tags applied to all deployed resources."
      }
    }
  },
  "variables": {
    "serverName": "[toLower(parameters('serverName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.DBforMySQL/flexibleServers",
      "apiVersion": "2023-06-30",
      "name": "[variables('serverName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[parameters('skuName')]",
        "tier": "[parameters('skuTier')]"
      },
      "properties": {
        "administratorLogin": "[parameters('administratorLogin')]",
        "administratorLoginPassword": "[parameters('administratorLoginPassword')]",
        "version": "[parameters('version')]",
        "storage": {
          "storageSizeGB": "[parameters('storageSizeGB')]",
          "iops": "[parameters('storageIops')]"
        },
        "backup": {
          "backupRetentionDays": "[parameters('backupRetentionDays')]",
          "geoRedundantBackup": "[parameters('geoRedundantBackup')]"
        },
        "highAvailability": {
          "mode": "[parameters('highAvailabilityMode')]"
        }
      }
    },
    {
      "type": "Microsoft.DBforMySQL/flexibleServers/firewallRules",
      "apiVersion": "2023-06-30",
      "name": "[format('{0}/{1}', variables('serverName'), 'AllowAll')]",
      "dependsOn": [
        "[resourceId('Microsoft.DBforMySQL/flexibleServers', variables('serverName'))]"
      ],
      "condition": "[parameters('allowAllIPs')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "255.255.255.255"
      }
    },
    {
      "type": "Microsoft.DBforMySQL/flexibleServers/databases",
      "apiVersion": "2023-06-30",
      "name": "[format('{0}/{1}', variables('serverName'), parameters('databaseName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.DBforMySQL/flexibleServers', variables('serverName'))]"
      ],
      "properties": {
        "charset": "utf8",
        "collation": "utf8_general_ci"
      }
    }
  ],
  "outputs": {
    "mysqlServerName": {
      "type": "string",
      "value": "[variables('serverName')]"
    },
    "mysqlServerId": {
      "type": "string",
      "value": "[resourceId('Microsoft.DBforMySQL/flexibleServers', variables('serverName'))]"
    },
    "mysqlServerEndpoint": {
      "type": "string",
      "value": "[format('{0}.mysql.database.azure.com', variables('serverName'))]"
    },
    "databaseName": {
      "type": "string",
      "value": "[parameters('databaseName')]"
    },
    "administratorLogin": {
      "type": "string",
      "value": "[parameters('administratorLogin')]"
    }
  }
}
